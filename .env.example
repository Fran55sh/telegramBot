APP_TIMEZONE=America/Argentina/Buenos_Aires
LOG_LEVEL=INFO

# development | dev | local => DATABASE_URL_LOCAL overrides DATABASE_URL when set.
# production | prod => DATABASE_URL only (ignore DATABASE_URL_LOCAL).
ENVIRONMENT=development

# Production (Docker/Coolify): persistent SQLite on mounted volume /app/data
DATABASE_URL=sqlite:////app/data/assistant.db

# Local dev only — do NOT set in production
DATABASE_URL_LOCAL=sqlite:///./assistant.db

TELEGRAM_BOT_TOKEN=123456789:your-bot-token-from-botfather
TELEGRAM_WEBHOOK_SECRET=change-me-long-random-secret

# Webhook URLs accepted by this app (POST):
#   /telegram/webhook  (recommended)
#   /webhook/telegram
#   /webhook

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
ENABLE_LLM_PARSER=false

# Optional: restrict bot + web API to these Telegram chat_id values (comma-separated).
# Private chat id usually equals your Telegram user id (see server logs: telegram_message chat_id=...).
# ALLOWED_TELEGRAM_IDS=123456789

REMINDER_CHECK_SECONDS=60

# Web GUI: secret token for Authorization: Bearer header on /api/* routes.
# Generate a long random string; must match VITE_WEB_APP_TOKEN in frontend build (or set in browser settings).
WEB_APP_TOKEN=change-me-long-random-web-token

# CORS for dev (Vite). In production with same-origin SPA, optional.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Frontend build-time only (Docker build args, NOT read at runtime by backend) ---
# VITE_WEB_APP_TOKEN=<same value as WEB_APP_TOKEN>
# VITE_TELEGRAM_CHAT_ID=<your numeric Telegram chat_id, NOT the bot token>
