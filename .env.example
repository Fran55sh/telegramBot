APP_TIMEZONE=America/Argentina/Buenos_Aires
LOG_LEVEL=INFO

# development | dev | local => use DATABASE_URL_LOCAL when set (typical on your PC).
# production | prod => DATABASE_URL only (Coolify / Docker; set in Compose or panel).
ENVIRONMENT=development

DATABASE_URL=sqlite:////app/data/assistant.db
DATABASE_URL_LOCAL=sqlite:///./assistant.db

# IMPORTANT (Coolify): do NOT set DATABASE_URL_LOCAL. Dockerfile sets ENVIRONMENT=production. Use DATABASE_URL=sqlite:////app/data/assistant.db + volume /app/data. If ENVIRONMENT=development with DATABASE_URL_LOCAL (pasted laptop .env), DB is ./assistant.db under /app, not /app/data — volume DB stays empty.

TELEGRAM_BOT_TOKEN=123456:telegram-token
TELEGRAM_WEBHOOK_SECRET=change-me

OPENAI_API_KEY=sk-proj-change-me
OPENAI_MODEL=gpt-5-mini

# Natural language parsing via OpenAI (v2.0). When false, only /g, /i, /r commands are accepted.
ENABLE_LLM_PARSER=false

# Optional whitelist of Telegram chat_id values (private chat id usually equals user id). If empty, any user can use the bot.
# ALLOWED_TELEGRAM_IDS=123456789,987654321

REMINDER_CHECK_SECONDS=60
