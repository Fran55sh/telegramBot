APP_TIMEZONE=America/Argentina/Buenos_Aires
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./assistant.db
# Docker / Coolify (volume mounted at /app/data): sqlite:////app/data/assistant.db

TELEGRAM_BOT_TOKEN=123456:telegram-token
TELEGRAM_WEBHOOK_SECRET=change-me

OPENAI_API_KEY=sk-proj-change-me
OPENAI_MODEL=gpt-5-mini

# Natural language parsing via OpenAI (v2.0). When false, only /g, /i, /r commands are accepted.
ENABLE_LLM_PARSER=false

# Optional whitelist of Telegram chat_id values (private chat id usually equals user id). If empty, any user can use the bot.
# ALLOWED_TELEGRAM_IDS=123456789,987654321

REMINDER_CHECK_SECONDS=60
